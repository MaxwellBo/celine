  <entry>
    <title>5.1.0</title>
    <link href="https://jsr.io/@celine/bibhtml@5.1.0"/>
    <id>https://jsr.io/@celine/bibhtml@5.1.0</id>
    <updated>2026-04-05T00:00:00Z</updated>
    <summary type="html"><![CDATA[
      Citation hover tooltips are positioned relative to the inline citation again, avoiding scroll drift by keeping the tooltip local to <code>&lt;bh-cite&gt;</code> rather than portaling it elsewhere in the document.
    ]]></summary>
  </entry>
  <entry>
    <title>5.0.0</title>
    <link href="https://jsr.io/@celine/bibhtml@5.0.0"/>
    <id>https://jsr.io/@celine/bibhtml@5.0.0</id>
    <updated>2026-04-05T00:00:00Z</updated>
    <summary type="html"><![CDATA[
      <code>replace</code> has been renamed to <code>marker</code>. <code>replacement</code> now only supports <code>"number"</code>; other values are ignored, and <code>marker=""</code> disables replacement.
    ]]></summary>
  </entry>
</feed>
